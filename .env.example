# .env.example – Kopiere diese Datei nach .env und passe die Werte an

# SMB/CIFS-Netzlaufwerk
SMB_SHARE=//server/Medidok
SMB_USERNAME=dein_username_hier
SMB_PASSWORD=dein_passwort_hier

# Flask Secret Key (zufälligen Wert generieren!)
SECRET_KEY=change-me-in-production

# Startseiten-URL (für Weiterleitungen)
HOME_URL=http://localhost:5000

# Zeitzone
TZ=Europe/Berlin
